{
  "name": "bypp-format",
  "version": "0.1.0",
  "description": "Beyond Paper format — open schema for tabletop RPG content",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.5.0",
    "vitest": "^1.4.0",
    "zod": "^3.22.4"
  },
  "license": "MIT"
}
