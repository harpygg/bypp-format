{
  "name": "bypp-format",
  "version": "12.0.0",
  "description": "Beyond Paper format — open schema for tabletop RPG content",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./v9": {
      "import": {
        "types": "./dist/v9.d.ts",
        "default": "./dist/v9.js"
      },
      "require": {
        "types": "./dist/v9.d.cts",
        "default": "./dist/v9.cjs"
      }
    },
    "./v10": {
      "import": {
        "types": "./dist/v10.d.ts",
        "default": "./dist/v10.js"
      },
      "require": {
        "types": "./dist/v10.d.cts",
        "default": "./dist/v10.cjs"
      }
    },
    "./v11": {
      "import": {
        "types": "./dist/v11.d.ts",
        "default": "./dist/v11.js"
      },
      "require": {
        "types": "./dist/v11.d.cts",
        "default": "./dist/v11.cjs"
      }
    },
    "./v12": {
      "import": {
        "types": "./dist/v12.d.ts",
        "default": "./dist/v12.js"
      },
      "require": {
        "types": "./dist/v12.d.cts",
        "default": "./dist/v12.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "tsup",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "zod": "^3.22.0"
  },
  "dependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.5.0"
  },
  "devDependencies": {
    "vitest": "^1.4.0",
    "zod": "^3.22.4"
  },
  "license": "MIT"
}
