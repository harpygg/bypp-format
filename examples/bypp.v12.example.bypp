  "randomTables": [
    {
      "uid": "JrShABmD4j1zAP0atme6",
      "title": "Encounters Across the Reach",
      "rows": [
        {
          "uid": "3x2DENRgYJuASjuS5EQ6",
          "range": 0,
          "content": "<span id=\"aB3x\" class=\"mceNonEditable\" data-roll=\"1d4\"> 1d4 </span> Gleamfang Panthers stalking through the canopy, eyes reflecting like coins in the undergrowth. They circle but do not attack unless cornered."
        },
        {
          "uid": "s3Rc4owe4qDFEoZ3lqXd",
          "range": 0,
          "content": "A lone Marsh Drake basking on a sun-warmed rock, its bioluminescent scales pulsing lazily. It hisses if approached but will trade passage for a fresh fish."
        },
        {
          "uid": "fw94Qhj3YMtJGQ2X4wj5",
          "range": 0,
          "content": "<p><span id=\"kR7m\" class=\"mceNonEditable\" data-roll=\"1d6\"> 1d6 </span> Chimeric Wisps drifting near a cracked Threshold. They shift shape constantly. Touching one forces a Wisdom save or the character glimpses a random fragment for 1d4 seconds.</p>"
        },
        {
          "uid": "SamL4S8krqsk52wsLIAv",
          "range": 0,
          "content": "<span id=\"pQ2n\" class=\"mceNonEditable\" data-roll=\"2d4\"> 2d4 </span> Inferno Elementals seeping from a volcanic vent. They are not hostile, but the ground within 30 feet is dangerously hot. A Cartographer's Guild marker nearby warns: DO NOT CAMP."
        },
        {
          "uid": "VuzOz6zuP4jT4Y0UVZLa",
          "range": 0,
          "content": "An Elerian Wyrm gliding overhead, impossibly large and silent. It circles twice, then banks toward the Windward Cliffs. The Wildling Clans say a wyrm circling means a Threshold just failed somewhere."
        },
        {
          "uid": "OAyoino0JAd0p2gttqXx",
          "range": 0,
          "content": "<span id=\"mW8v\" class=\"mceNonEditable\" data-roll=\"1d4\"> 1d4 </span> Amberlake Spirits hovering over still water at dusk. Their glow is warm and inviting. Anyone who follows them for more than ten minutes must make a Charisma save or lose track of time until dawn."
        },
        {
          "uid": "ZHsciyvjkKfwJdOdhvTa",
          "range": 0,
          "content": "A wounded Bridge Keeper sitting against a collapsed span, clutching a satchel of repair tools. She says the bridge fell on its own. Her eyes say otherwise."
        },
        {
          "uid": "9TdeBcBD7Iu4m4Fwf4YM",
          "range": 0,
          "content": "A Skybreaker Skiff drifting unmanned, its sail torn, bumping gently against a cliff face. The cargo hold contains sealed Cartographer's Guild charts and a half-eaten meal still warm."
        }
      ]
    }
  ],
