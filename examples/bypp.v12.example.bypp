      ],
      "isHiddenFromSheet": false,
      "label": "Spellcasting Modifier",
      "type": "formula",
      "formula": "<p>IF( <span class=\"mceNonEditable\" data-variable=\"sYZSn2sHXYrpaNblz5wL\">$Spellcasting ability</span> ,</p>\n<p> SWITCH_CONTAINS(</p>\n<p>  <span class=\"mceNonEditable\" data-variable=\"sYZSn2sHXYrpaNblz5wL\" data-variable-state=\"ok\">$Spellcasting ability</span> ,</p>\n<p>  \"cha\", <span class=\"mceNonEditable\" data-variable=\"5dqmtpOKLcYLmARqXyE0\" data-variable-state=\"ok\">$Charisma (mod)</span> ,</p>\n<p>  \"wis\", <span class=\"mceNonEditable\" data-variable=\"gkUDaWw041CPbTeWaRFo\" data-variable-state=\"ok\">$Wisdom (mod)</span>  ,</p>\n<p>  \"dex\", <span class=\"mceNonEditable\" data-variable=\"6Db2v59dLYgrKQhX8xW5\">$Dexterity (mod)</span> ,</p>\n<p>  \"con\", <span class=\"mceNonEditable\" data-variable=\"TnvtbzZASMQDALM0gLKN\">$Constitution (mod)</span> ,</p>\n<p>  \"str\", <span class=\"mceNonEditable\" data-variable=\"bqqcVDTWiYiBPtotYW3l\">$Strength (mod)</span> ,</p>\n<p>  \"int\", <span class=\"mceNonEditable\" data-variable=\"U6TcdcIFltxmPw2keR81\" data-variable-state=\"ok\">$Intelligence (mod)</span>  </p>\n<p> ),</p>\n<p> 0</p>\n<p>)</p>"
    },
