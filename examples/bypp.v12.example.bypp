    {
      "uid": "3LHNJJqt0VX9ZWibUuCg",
      "name": "Animal Handling Mod",
      "datasetsUids": [
        "IWNSh0lQb3fyqUgW1R9X"
      ],
      "isHiddenFromSheet": false,
      "label": "Animal Handling Mod",
      "type": "formula",
      "formula": "<p><span class=\"mceNonEditable\" data-variable=\"gkUDaWw041CPbTeWaRFo\" data-variable-state=\"ok\">$Wisdom (mod)</span>+ROUNDDOWN(<span class=\"mceNonEditable\" data-variable=\"HouITOmrZKxfUG77Qm0s\" data-variable-state=\"ok\">$Animal Handling mastery</span> * <span class=\"mceNonEditable\" data-variable=\"kOiOThjodZBjPnReNHJZ\" data-variable-state=\"ok\">$Proficiency Bonus</span> , 0)</p>\n<p> </p>"
    },
    {
      "uid": "5UeMbPgGdKaeAXPJiAqv",
