      "formula": "<p><span class=\"mceNonEditable\" data-variable=\"5dqmtpOKLcYLmARqXyE0\" data-variable-state=\"ok\">$Charisma (mod)</span>+ROUNDDOWN(<span class=\"mceNonEditable\" data-variable=\"D7yZakafZHQRPNpCRHTu\" data-variable-state=\"ok\">$Intimidation mastery</span> * <span class=\"mceNonEditable\" data-variable=\"kOiOThjodZBjPnReNHJZ\" data-variable-state=\"ok\">$Proficiency Bonus</span> , 0)</p>\n<p> </p>"
    },
